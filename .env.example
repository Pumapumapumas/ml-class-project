# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit it.
# See docs/standards/credential_handling_standard.md for the full policy.

# === LLM API keys (required for OCR pipeline) ===

# Google Gemini — free tier available
# Obtain at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key-here

# OpenAI GPT-4o — paid
# Obtain at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key-here

# Anthropic Claude — paid
# Obtain at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-key-here

# === HuggingFace (required for dataset access) ===

# Used by scripts/download_dataset.py
# Obtain at https://huggingface.co/settings/tokens (read access is enough)
HUGGINGFACE_TOKEN=your-huggingface-token-here

# === Optional configuration ===

# Default OCR model when not specified on the CLI
DEFAULT_OCR_MODEL=gemini

# Maximum concurrent API calls (rate-limit safety)
MAX_CONCURRENT_REQUESTS=4

# Pipeline log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
